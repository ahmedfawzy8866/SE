# ─── Firebase client config (public, safe to expose) ────────────────────────
# Get these from Firebase Console → Project Settings → General → Your apps.
# All values are public by design — Firebase security is enforced via Firestore
# Rules + Auth, not by hiding these keys.

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# ─── Admin API key (for /api/houyez/seed and other admin endpoints) ─────────
# Set this to any random string — clients must send it in the x-admin-key
# header to call admin endpoints. Generate one with:
#   openssl rand -hex 32
ADMIN_API_KEY=change_me_to_a_long_random_string

# ─── App config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
