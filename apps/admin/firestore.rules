rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        // Hardcoded admin emails (primary method)
        request.auth.token.email != null && (
          request.auth.token.email == "emeraldestatesegypt@gmail.com" ||
          request.auth.token.email == "a.fawzy8866@gmail.com"
        ) ||
        // Admin UID fallback
        request.auth.uid == "n5AwnuWrwhTm5brJJiJDU6uJunM2" ||
        // Admin collection check
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // ═══════════════════════════════════════════════════════════════════
    //  PUBLIC READ — Compounds + Active Listings (client portal)
    // ═══════════════════════════════════════════════════════════════════

    match /compounds/{compoundId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /listings/{listingId} {
      // Public can read active listings; signed-in can read all
      allow read: if true;
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /agents/{agentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  PUBLIC CREATE — Inquiries + Career Applications (website forms)
    // ═══════════════════════════════════════════════════════════════════

    match /inquiries/{inquiryId} {
      allow create: if true;   // anyone can submit inquiry
      allow read, update, delete: if isAdmin();
    }

    match /career_applications/{appId} {
      allow create: if true;   // anyone can apply
      allow read, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;   // n8n / Property Finder webhook
      allow read, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  ADMIN ONLY — CRM + Workflow data (Zero-Trust PII)
    // ═══════════════════════════════════════════════════════════════════

    match /owners/{ownerId} {
      allow read, write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    match /requests/{requestId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  SYSTEM COLLECTIONS (admin only)
    // ═══════════════════════════════════════════════════════════════════

    match /workflows/{workflowId} {
      allow read, write: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == adminId);
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /searches/{searchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system_health/{metricId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  CATCH-ALL: deny everything else
    // ═══════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
