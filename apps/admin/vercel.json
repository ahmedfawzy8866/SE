{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "sierra-estates-admin",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["fra1"],
  "env": {
    "VITE_FIREBASE_API_KEY": "@sierra-firebase-api-key",
    "VITE_FIREBASE_AUTH_DOMAIN": "@sierra-firebase-auth-domain",
    "VITE_FIREBASE_PROJECT_ID": "@sierra-firebase-project-id",
    "VITE_FIREBASE_STORAGE_BUCKET": "@sierra-firebase-storage-bucket",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "@sierra-firebase-messaging-sender-id",
    "VITE_FIREBASE_APP_ID": "@sierra-firebase-app-id"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
