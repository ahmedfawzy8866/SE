rules_version = '2';

// ============================================================================
// Sierra Estates — Firestore Security Rules (CANONICAL — deployed via firebase.json)
//
// Model: "staff" = a signed-in user whose users/{uid} document has
//   role ∈ {admin, manager, agent}. Mirrors how the app resolves roles
//   (lib/AuthContext.tsx reads users/{uid}.role) and the backend
//   verifyAdminRequest. This REPLACES the legacy admins/{uid} model.
//
// Privileged server operations use the Firebase Admin SDK, which BYPASSES these
// rules — so locking the client down here does not affect API routes / cron.
//
// Rules use OR semantics: the broad `/{collection}/{document=**}` staff rule
// grants staff access everywhere EXCEPT /users (carved out — see below); the
// specific matches ADD narrower public access on top (public catalog reads,
// public share-link gets + constrained analytics writes).
//
// ⚠️ BEFORE DEPLOYING (firebase deploy --only firestore:rules):
//   1. Every staff member MUST have a users/{uid} doc with role ∈
//      {admin,manager,agent}, else they lose dashboard access.
//   2. Run the emulator rules tests (scripts/test-firestore-rules.mjs) — the
//      constrained-update rules below must be verified against the actual
//      client payloads.
//   3. Roll back by redeploying the previous file if anything is locked out.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'agent'];
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Public marketplace catalog: anyone may read PUBLISHED items; only
    //     staff may write. Staff read everything via the catch-all below.
    //     ⚠️ Phase 1 change: public reads are now status-gated. The client
    //     portal MUST filter its queries with status == 'published' (or read
    //     server-side via Admin SDK / ISR) or its queries will be denied.
    function isPublished() {
      return resource.data.status == 'published';
    }
    match /listings/{id}    { allow read: if isPublished() || isStaff();  allow write: if isStaff(); }
    match /units/{id}       { allow read: if isPublished() || isStaff();  allow write: if isStaff(); }
    match /properties/{id}  { allow read: if isPublished() || isStaff();  allow write: if isStaff(); }
    match /compounds/{id}   { allow read: if isPublished() || isStaff();  allow write: if isStaff(); }
    match /projects/{id}    { allow read: if true;  allow write: if isStaff(); }
    match /developers/{id}  { allow read: if true;  allow write: if isStaff(); }
    match /mediaAssets/{id} { allow read: if true;  allow write: if isStaff(); }
    match /media/{id}       { allow read: if true;  allow write: if isStaff(); }
    match /zones/{id}       { allow read: if true;  allow write: if isStaff(); }

    // --- Public share links: recipients open these via an unguessable URL
    //     (no login). They may GET a single doc by id, and record lightweight
    //     typed analytics ONLY. LIST is staff-only so the collections cannot
    //     be enumerated (they contain lead PII — the share-link model relies
    //     on the doc id being the capability). Substantive writes are staff
    //     (or Admin SDK — today app/api/proposals and app/api/concierge/[leadId]
    //     serve these server-side, so the public grants below are for the
    //     client-rendered share pages). ---
    match /proposals/{id} {
      allow get: if true;
      allow list: if isStaff();
      allow update: if isStaff()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'lastViewedAt'])
            && request.resource.data.viewCount is int
            && request.resource.data.lastViewedAt is timestamp);
      allow create, delete: if isStaff();
    }
    match /concierge_selections/{id} {
      allow get: if true;
      allow list: if isStaff();
      allow update: if isStaff()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['engagement'])
            && request.resource.data.engagement is map);
      allow create, delete: if isStaff();
    }

    // --- Houyez-Style client portal (src/app/clients, public marketing site):
    //     public read so the portal renders without auth.
    //     ⚠️ Phase 1 change (zero-trust): writes tightened from isSignedIn()
    //     to isStaff(). Previously ANY signed-in account could modify the
    //     public catalog. If a legitimate non-staff write flow exists (e.g.
    //     client tour bookings), route it through the VPS/n8n Admin SDK.
    match /houyez_slides/{doc}     { allow read: if true; allow write: if isStaff(); }
    match /houyez_compounds/{doc}  { allow read: if true; allow write: if isStaff(); }
    match /houyez_rooms/{doc}      { allow read: if true; allow write: if isStaff(); }
    match /houyez_listings/{doc}   { allow read: if true; allow write: if isStaff(); }
    match /houyez_tours/{doc}      { allow read: if true; allow write: if isStaff(); }

    // --- Users: a user may read their own profile; staff may update profiles
    //     but ONLY admins may touch the `role` field — otherwise any agent
    //     could promote themselves to admin (and role==='admin' is what the
    //     backend verifyAdminRequest trusts). Create/delete are admin-only;
    //     new staff docs are provisioned server-side via the Admin SDK anyway.
    //     NOTE: /users is deliberately excluded from the staff catch-all below.
    match /users/{uid} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isStaff() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // --- Everything else (leads, deals, sales, viewings, vouchers, activities,
    //     intelligence, strategic_pipeline, agents, workflows, syncQueue, … )
    //     — staff only. /users is carved out so this broad grant cannot
    //     bypass the role-change restriction above (rules are OR-semantics:
    //     any matching allow wins). ---
    match /{collection}/{document=**} {
      allow read, write: if isStaff() && collection != 'users';
    }
  }
}
