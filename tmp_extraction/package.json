{
  "name": "se",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Sierra Estates — pnpm + Turborepo monorepo. The Next.js app lives in apps/sierra-estates-realty.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:functions": "firebase deploy --only functions"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": { "node": ">=20" }
}
