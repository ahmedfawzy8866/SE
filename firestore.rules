rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Sierra Estates — Firestore Security Rules
// ═══════════════════════════════════════════════════════════════════════════
//
//  HOW TO DEPLOY:
//  1. Install Firebase CLI:  npm install -g firebase-tools
//  2. Login:                 firebase login
//  3. Link project:          firebase use --add  (select your project)
//  4. Deploy these rules:    firebase deploy --only firestore:rules
//
//  Or via Firebase Console:
//  1. Go to console.firebase.google.com → your project
//  2. Build → Firestore Database → Rules tab
//  3. Paste the rules below + click "Publish"
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Compounds: public read, admin write only ──
    match /compounds/{compoundId} {
      allow read: if true;  // public — anyone can browse compounds
      allow write: if isAdmin();
    }

    // ── Listings: public read, admin write only ──
    match /listings/{listingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Units: public read, admin write only ──
    match /units/{unitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Agents: public read, admin write only ──
    match /agents/{agentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Inquiries: ANYONE can create (form submission) ──
    // Only admins can read (privacy — protect user data)
    match /inquiries/{inquiryId} {
      allow create: if true;  // public form submission
      allow read, update, delete: if isAdmin();
    }

    // ── Career applications: ANYONE can create ──
    // Only admins can read (privacy — protect applicant data)
    match /career_applications/{appId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Leads (from Property Finder webhook): admin only ──
    match /leads/{leadId} {
      allow read, write: if isAdmin();
    }

    // ── Users (admin profiles): each user can read own doc ──
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ── Helper function: check if user is admin ──
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
