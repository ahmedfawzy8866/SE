rules_version = '2';

// ─── Sierra Estates (SE) — Firestore Security Rules ────────────────────────
// Default stance: public READ for the Houyez collections (the portal needs to
// render without auth), admin-only WRITE. Auth is wired via Firebase Auth —
// any signed-in user can write for now. Tighten this to a specific admin
// role (e.g. custom claims) before going to production.

service cloud.firestore {
  match /databases/{database}/documents {

    // Houyez portal collections — public read, signed-in write
    match /houyez_slides/{doc}     { allow read: if true; allow write: if request.auth != null; }
    match /houyez_compounds/{doc}  { allow read: if true; allow write: if request.auth != null; }
    match /houyez_rooms/{doc}      { allow read: if true; allow write: if request.auth != null; }
    match /houyez_listings/{doc}   { allow read: if true; allow write: if request.auth != null; }
    match /houyez_tours/{doc}      { allow read: if true; allow write: if request.auth != null; }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
